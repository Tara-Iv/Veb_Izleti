{
  "name": "veb_izleti",
  "version": "1.0.0",
  "description": "Veb aplikacija za online rezervaciju turistickih izleta MERN stack",
  "license": "MIT",
  "author": "Tara Ivosevic",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node backend/server.js",
    "server": "nodemon backend/server.js",
    "client": "npm start --prefix frontend",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "data:import": "node backend/seeder.js",
    "data:destroy": "node backend/seeder.js -d"
},
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "colors": "^1.4.0",
    "cookie-parser": "^1.4.7",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.7.0",
    "nodemailer": "^8.0.11"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "dotenv": "^17.4.2",
    "nodemon": "^3.1.14"
  }
}
